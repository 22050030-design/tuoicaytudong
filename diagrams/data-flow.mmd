%%{init: {'theme': 'base'}}%%

graph LR
    subgraph INPUT["DAU VAO"]
        S1["Cảm biến độ ẩm đất<br/>Analog → %"]
        S2["Cảm biến mực nước<br/>Analog → ON/OFF"]
        S3["DHT22<br/>T(°C) + RH(%)"]
        B1["Nút Auto/Manual"]
        B2["Nút tưới thủ công"]
        B3["Nút Reset"]
    end

    subgraph ESP["ESP32 XU LY"]
        subgraph SENSOR_TASK["SensorTask (1s, Core 0)"]
            READ["Đọc cảm biến"]
            FILTER["Lọc Moving Average"]
            CONVERT["Chuyển đổi đơn vị"]
        end

        subgraph QUEUE_SYS["QUEUE &amp; MUTEX"]
            Q1["xQueueOverwrite<br/>(1 phần tử)"]
            MX1["xMutex<br/>Bảo vệ state chung"]
            EG1["EventGroup<br/>WIFI, WATER, SENSOR flags"]
        end

        subgraph CONTROL_TASK["ControlTask (100ms, Core 1)"]
            FSM["FSM Logic<br/>7 trạng thái"]
            DECIDE["Ra quyết định<br/>Bật/Tắt bơm"]
        end

        subgraph SAFETY_TASK["SafetyTask (100ms, Core 1)"]
            CHECK_TIME["Kiểm tra timeout 15s"]
            CHECK_WATER["Kiểm tra nước"]
            CHECK_SENSOR["Kiểm tra cảm biến"]
        end

        subgraph DISPLAY_TASK["DisplayTask (500ms, Core 0)"]
            LCD_UP["Cập nhật LCD"]
            LED_UP["Cập nhật LED"]
            BUZ_UP["Cập nhật Buzzer"]
        end

        subgraph IOT_TASK["IoTTask (2s, Core 0)"]
            SEND["Gửi dữ liệu<br/>Blynk V0-V5"]
            RECV["Nhận lệnh<br/>Blynk V6"]
        end
    end

    subgraph OUTPUT["DAU RA"]
        RELAY["Relay → Máy bơm"]
        LCD["LCD Display"]
        LEDs["LED Status"]
        BUZZER["Buzzer"]
    end

    subgraph CLOUD["BLYNK 2.0"]
        PLATFORM["Blynk Cloud"]
        WEB["Web Dashboard"]
        APP["Mobile App"]
    end

    S1 & S2 & S3 --> READ
    B1 & B2 --> DECIDE
    B3 --> FSM

    READ --> FILTER --> CONVERT --> Q1
    Q1 --> FSM
    MX1 --> FSM
    EG1 --> FSM

    FSM --> DECIDE
    CHECK_TIME & CHECK_WATER & CHECK_SENSOR --> DECIDE

    DECIDE --> RELAY
    DECIDE --> LCD_UP & LED_UP & BUZ_UP
    LCD_UP --> LCD
    LED_UP --> LEDs
    BUZ_UP --> BUZZER

    CONVERT --> SEND --> PLATFORM --> WEB & APP
    RECV --> DECIDE

    style INPUT fill:#4CAF50,stroke:#2E7D32,color:#fff
    style ESP fill:#2196F3,stroke:#1565C0,color:#fff
    style OUTPUT fill:#F44336,stroke:#C62828,color:#fff
    style CLOUD fill:#00BCD4,stroke:#00838F,color:#fff
    style SENSOR_TASK fill:#66BB6A,stroke:#388E3C,color:#fff
    style CONTROL_TASK fill:#42A5F5,stroke:#1565C0,color:#fff
    style SAFETY_TASK fill:#EF5350,stroke:#C62828,color:#fff
    style DISPLAY_TASK fill:#AB47BC,stroke:#6A1B9A,color:#fff
    style IOT_TASK fill:#26C6DA,stroke:#00838F,color:#fff
    style QUEUE_SYS fill:#FFA726,stroke:#E65100,color:#fff
