%%{init: {'theme': 'base'}}%%

graph TB
    subgraph FREERTOS["FREERTOS KERNEL - ESP32 DUAL CORE"]
        subgraph TASKS["5 TASKS"]
            direction LR

            subgraph T1["SensorTask"]
                T1_INFO["Chu kỳ: 1s | Stack: 2048B<br/>Priority: 2 | Core: 0"]
                T1_DO["- Đọc đất, DHT22, mực nước<br/>- Moving Average filter<br/>- xQueueOverwrite → ControlTask"]
            end

            subgraph T2["ControlTask"]
                T2_INFO["Chu kỳ: 100ms | Stack: 4096B<br/>Priority: 3 | Core: 1"]
                T2_DO["- Xử lý FSM 7 trạng thái<br/>- Điều khiển Relay<br/>- Nhận lệnh nút nhấn"]
            end

            subgraph T3["DisplayTask"]
                T3_INFO["Chu kỳ: 500ms | Stack: 2048B<br/>Priority: 1 | Core: 0"]
                T3_DO["- Cập nhật LCD I2C<br/>- Điều khiển LED<br/>- Điều khiển Buzzer"]
            end

            subgraph T4["IoTTask"]
                T4_INFO["Chu kỳ: 2s | Stack: 8192B<br/>Priority: 2 | Core: 0"]
                T4_DO["- Gửi dữ liệu Blynk V0-V5<br/>- Nhận lệnh Blynk V6<br/>- Quản lý Wi-Fi reconnect"]
            end

            subgraph T5["SafetyTask"]
                T5_INFO["Chu kỳ: 100ms | Stack: 2048B<br/>Priority: 4 (cao nhất) | Core: 1"]
                T5_DO["- Timeout bơm 15s<br/>- Kiểm tra hết nước<br/>- Kiểm tra lỗi cảm biến<br/>- BẮT BUỘC tắt bơm"]
            end
        end

        subgraph SYNC["CO SO SYNCHRONIZATION"]
            direction LR

            subgraph Q["Queue (1 phần tử)"]
                Q_DESC["xQueueOverwrite<br/>Truyền SensorData<br/>SensorTask → ControlTask"]
                Q_SIZE["1 phần tử sizeof(SensorData)<br/>Ghi đè liên tục"]
            end

            subgraph MX["Mutex"]
                MX_DESC["xStateMutex<br/>Bảo vệ state chung"]
                MX_PROTECT["- g_sensorData<br/>- g_fsmState<br/>- g_pumpOn<br/>- g_alarmActive"]
            end

            subgraph EG["Event Group"]
                EG_DESC["xEventGroup<br/>Cờ trạng thái"]
                EG_FLAGS["BIT_WIFI_CONNECTED<br/>BIT_IOT_CONNECTED<br/>BIT_WATER_EMPTY<br/>BIT_SENSOR_ERROR<br/>BIT_PUMP_RUNNING"]
            end

            subgraph SEM["Semaphore"]
                SEM_DESC["xBtnSem<br/>Báo hiệu sự kiện"]
                SEM_USE["- ISR_BtnWater → ControlTask<br/>- ISR_BtnReset → SafetyTask"]
            end
        end
    end

    T1 -->|"xQueueOverwrite<br/>(SensorData)"| Q
    Q -->|"xQueueReceive<br/>(SensorData)"| T2
    T2 -->|"xSemaphoreTake<br/>Update state"| MX
    T3 -->|"xSemaphoreTake<br/>Read state"| MX
    T4 -->|"xEventGroup<br/>Check WIFI"| EG
    T5 -->|"xEventGroup<br/>Set WATER_EMPTY"| EG
    T5 -->|"xSemaphoreGive<br/>ALARM"| SEM
    SEM -->|"xSemaphoreTake<br/>Handle ALARM"| T2

    style FREERTOS fill:#1a237e,stroke:#0D47A1,stroke-width:3px,color:#fff
    style TASKS fill:#1565C0,stroke:#0D47A1,color:#fff
    style T1 fill:#43A047,stroke:#2E7D32,color:#fff
    style T2 fill:#1E88E5,stroke:#1565C0,color:#fff
    style T3 fill:#8E24AA,stroke:#6A1B9A,color:#fff
    style T4 fill:#00ACC1,stroke:#00838F,color:#fff
    style T5 fill:#E53935,stroke:#C62828,color:#fff
    style SYNC fill:#F57C00,stroke:#E65100,color:#fff
    style Q fill:#FFB300,stroke:#FF8F00,color:#000
    style MX fill:#FF8F00,stroke:#E65100,color:#fff
    style EG fill:#FB8C00,stroke:#EF6C00,color:#fff
    style SEM fill:#FFA000,stroke:#FF6F00,color:#000
