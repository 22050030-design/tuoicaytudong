%%{init: {'theme': 'base'}}%%

graph TB
    subgraph DASHBOARD["GIAO DIEN BLYNK 2.0"]
        direction TB

        subgraph ROW1["HANG 1 - BIEU DO &amp; DONG HO"]
            GAUGE1["V0: Đồng hồ độ ẩm đất<br/>0% ──── 100%<br/>Ngưỡng: 35% (đỏ) - 60% (xanh)"]
            GAUGE2["V1: Đồng hồ nhiệt độ<br/>-10°C ── 50°C"]
            GAUGE3["V2: Đồng hồ độ ẩm KK<br/>0% ──── 100%"]
        end

        subgraph ROW2["HANG 2 - TRANG THAI"]
            ST_WATER["V3: Mực nước<br/>1 = Còn nước / 0 = Hết"]
            ST_PUMP["V4: Máy bơm<br/>1 = ON / 0 = OFF"]
            ST_MODE["V5: FSM State<br/>0-6 tương ứng 7 trạng thái"]
        end

        subgraph ROW3["HANG 3 - DIEU KHIEN"]
            BTN_MANUAL["V6: Nút BẬT/TẮT<br/>Tưới thủ công"]
        end

        subgraph ROW4["HANG 4 - CANH BAO"]
            NOTI_WARN["Cảnh báo hết nước"]
            NOTI_ERR["Lỗi cảm biến"]
            NOTI_PUMP["Bơm quá thời gian"]
            NOTI_WIFI["Mất kết nối"]
        end
    end

    subgraph DEVICE["ESP32 - THIET BI"]
        WIFI_MOD["Wi-Fi STA Mode"]
        BLYNK_CLI["Blynk Library<br/>BLYNK_WRITE(V6)"]
    end

    subgraph CLOUD_SVC["BLYNK CLOUD"]
        SERVER["Blynk Server<br/>(Asia Region)"]
    end

    WIFI_MOD <-->|"TCP/IP"| SERVER
    BLYNK_CLI --> WIFI_MOD
    DASHBOARD <-->|"WebSocket"| SERVER

    style DASHBOARD fill:#E3F2FD,stroke:#1565C0,stroke-width:2px
    style ROW1 fill:#4CAF50,stroke:#2E7D32,color:#fff
    style ROW2 fill:#2196F3,stroke:#1565C0,color:#fff
    style ROW3 fill:#FF9800,stroke:#E65100,color:#fff
    style ROW4 fill:#F44336,stroke:#C62828,color:#fff
    style DEVICE fill:#1565C0,stroke:#0D47A1,color:#fff
    style CLOUD_SVC fill:#00ACC1,stroke:#00838F,color:#fff
    style GAUGE1 fill:#66BB6A,stroke:#388E3C,color:#fff
    style GAUGE2 fill:#EF5350,stroke:#C62828,color:#fff
    style GAUGE3 fill:#42A5F5,stroke:#1565C0,color:#fff
    style BTN_MANUAL fill:#FF7043,stroke:#D84315,color:#fff
