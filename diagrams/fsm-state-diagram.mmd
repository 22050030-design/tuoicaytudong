stateDiagram-v2
    [*] --> INIT

    INIT --> MONITORING : Khởi tạo thành công<br/>(Cảm biến, LCD, Wi-Fi OK)

    state MONITORING {
        [*] --> DocCamBien
        DocCamBien --> KiemTraDieuKien
        KiemTraDieuKien --> DocCamBien
    }

    MONITORING --> AUTO_WATERING : Đất khô (doMuc &lt; 35%)<br/>VÀ bồn còn nước

    MONITORING --> MANUAL_WATERING : Nhận lệnh tưới<br/>(Nút nhấn hoặc Blynk V6)

    MONITORING --> ALARM : Đất khô + Hết nước

    MONITORING --> OFFLINE : Mất kết nối Wi-Fi

    state AUTO_WATERING {
        [*] --> BatBom
        BatBom --> DangTuoi : Relay ON
        DangTuoi --> KiemTraAnToan
        KiemTraAnToan --> DangTuoi : An toàn
        KiemTraAnToan --> TatBom : Đủ ẩm hoặc Timeout
    }

    AUTO_WATERING --> COOLDOWN : Đất đủ ẩm (doMuc >= 60%)

    AUTO_WATERING --> ALARM : Hết nước<br/>Hoặc bơm quá 15 giây

    state MANUAL_WATERING {
        [*] --> BatBomTC
        BatBomTC --> DangTuoiTC : Relay ON
        DangTuoiTC --> KiemTraATTC
        KiemTraATTC --> DangTuoiTC : An toàn
        KiemTraATTC --> TatBomTC : Timeout
    }

    MANUAL_WATERING --> COOLDOWN : Nhấn nút ngừng tưới

    MANUAL_WATERING --> ALARM : Hết nước<br/>Hoặc bơm quá 15 giây

    state COOLDOWN {
        [*] --> ChoNuocNgam
        ChoNuocNgam --> DoLai : 30 giây
    }

    COOLDOWN --> MONITORING : Hết 30 giây chờ

    state ALARM {
        [*] --> BaoLoi
        BaoLoi --> ChoXuLy : LED đỏ nhấp nháy + Buzzer
    }

    ALARM --> MONITORING : Xử lý lỗi + Nhấn Reset

    state OFFLINE {
        [*] --> HoatDongTaiCho
        HoatDongTaiCho --> TuoiTuDong : Vẫn đọc cảm biến<br/>Và điều khiển bơm
    }

    OFFLINE --> MONITORING : Wi-Fi khôi phục

    note right of INIT
        Khởi tạo:
        - Cảm biến, LCD
        - Wi-Fi STA Mode
        - Blynk 2.0
    end note

    note left of MONITORING
        Trạng thái chính:
        - Đọc cảm biến mỗi 1s
        - Kiểm tra điều kiện tưới
        - Gửi dữ liệu Blynk
    end note

    note right of AUTO_WATERING
        Tưới tự động:
        - Relay ON
        - Timeout 15 giây
        - LED vàng sáng
    end note

    note left of ALARM
        Cảnh báo:
        - LED đỏ nhấp nháy
        - Buzzer kêu
        - Bơm TẮT ngay
    end note

    note right of OFFLINE
        Mất Wi-Fi:
        - Vẫn tưới tự động
        - Không gửi Blynk
        - LED xanh nhấp nháy
    end note
